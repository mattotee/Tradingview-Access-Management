# ─────────────────────────────────────────────────────
# TMM TradingView Gateway - Environment Variables
# Copy this file to .env and fill in the values.
# NEVER commit .env to git.
# ─────────────────────────────────────────────────────

# TradingView service account credentials (TMMEdge account)
TV_SERVICE_USERNAME=TMMEdge
TV_SERVICE_PASSWORD=your_tmmEdge_password_here

# TMM API key - Make sends this in X-API-Key header on every request
# Generate a strong random string e.g: openssl rand -hex 32
TMM_API_KEY=generate_a_strong_random_key_here

# TradingView Indicator Pine IDs
TV_VCI_ID=PUB;51ca8acd0b0d4ac00bd9684a3d989a427
TV_CCO_ID=PUB;ffa472cc81d34f908514dc05946cf84a
TV_CCPRO_ID=PUB;c37df8f0c33c41b1afccf49df071009a
TV_VPI_ID=PUB;y7e62ed783a64aa99b6a302f1b2d97a3
TV_WCO_ID=PUB;5477dfc3518642228abbe2d6c5b55579

# Session cache file path (writable location on VPS)
SESSION_FILE=/home/tmm/tv_session.json

# Port (default 5001 - sits alongside Engine bot dashboard on 8765)
PORT=5001
